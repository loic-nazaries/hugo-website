#!/bin/sh
# pre-push hook: rebuild public/ with hugo before every push.
# If hugo produces changes, they are committed automatically.

echo ">>> Running hugo build before push..."

if ! hugo; then
  echo "ERROR: hugo build failed. Push aborted." >&2
  exit 1
fi

# Stage any changes inside public/
git add public/

# If there are staged changes, commit them
if ! git diff --cached --quiet; then
  git commit -m "chore: rebuild public/ [pre-push]"
  echo ">>> public/ rebuilt and committed."
else
  echo ">>> public/ is already up to date."
fi
