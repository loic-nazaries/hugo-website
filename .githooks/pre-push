#!/bin/sh
# pre-push hook: verify the hugo build succeeds before pushing.
# public/ is built by CI (GitHub Actions) and is not committed to git.

echo ">>> Verifying hugo build --gc --minify before push..."

if ! hugo --gc --minify; then
  echo "ERROR: hugo build --gc --minify failed. Push aborted." >&2
  exit 1
fi

echo ">>> Hugo build succeeded."
